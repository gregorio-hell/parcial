@model IEnumerable<parcial.Models.Matricula>
@{
    ViewData["Title"] = "Mis Matrículas";
}

<div class="container">
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4">
                <i class="fas fa-user-graduate"></i> Mis Matrículas
            </h2>

            <!-- Mensajes -->
            @if (TempData["MensajeExito"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle"></i> 
                    <strong>¡Éxito!</strong> @TempData["MensajeExito"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["MensajeError"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-triangle"></i> 
                    <strong>Error:</strong> @TempData["MensajeError"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (User.Identity?.IsAuthenticated == true)
            {
                if (Model.Any())
                {
                    <!-- Estadísticas rápidas -->
                    <div class="row mb-4">
                        <div class="col-md-3">
                            <div class="card bg-warning text-white">
                                <div class="card-body text-center">
                                    <i class="fas fa-clock fa-2x"></i>
                                    <h4>@Model.Count(m => m.Estado == parcial.Models.EstadoMatricula.Pendiente)</h4>
                                    <small>Pendientes</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-success text-white">
                                <div class="card-body text-center">
                                    <i class="fas fa-check fa-2x"></i>
                                    <h4>@Model.Count(m => m.Estado == parcial.Models.EstadoMatricula.Confirmada)</h4>
                                    <small>Confirmadas</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-danger text-white">
                                <div class="card-body text-center">
                                    <i class="fas fa-times fa-2x"></i>
                                    <h4>@Model.Count(m => m.Estado == parcial.Models.EstadoMatricula.Cancelada)</h4>
                                    <small>Canceladas</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-info text-white">
                                <div class="card-body text-center">
                                    <i class="fas fa-award fa-2x"></i>
                                    <h4>@Model.Where(m => m.Estado == parcial.Models.EstadoMatricula.Confirmada).Sum(m => m.Curso?.Creditos ?? 0)</h4>
                                    <small>Créditos Confirmados</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Lista de matrículas -->
                    <div class="row">
                        @foreach (var matricula in Model)
                        {
                            <div class="col-lg-6 mb-4">
                                <div class="card h-100">
                                    <div class="card-header d-flex justify-content-between align-items-center">
                                        <h6 class="mb-0">
                                            <strong>@matricula.Curso?.Codigo</strong> - @matricula.Curso?.Nombre
                                        </h6>
                                        @switch (matricula.Estado)
                                        {
                                            case parcial.Models.EstadoMatricula.Pendiente:
                                                <span class="badge bg-warning">
                                                    <i class="fas fa-clock"></i> Pendiente
                                                </span>
                                                break;
                                            case parcial.Models.EstadoMatricula.Confirmada:
                                                <span class="badge bg-success">
                                                    <i class="fas fa-check"></i> Confirmada
                                                </span>
                                                break;
                                            case parcial.Models.EstadoMatricula.Cancelada:
                                                <span class="badge bg-danger">
                                                    <i class="fas fa-times"></i> Cancelada
                                                </span>
                                                break;
                                        }
                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-6">
                                                <small class="text-muted">Créditos:</small>
                                                <p class="mb-1"><strong>@matricula.Curso?.Creditos</strong></p>
                                            </div>
                                            <div class="col-6">
                                                <small class="text-muted">Horario:</small>
                                                <p class="mb-1">
                                                    @matricula.Curso?.HorarioInicio.ToString("HH:mm") - 
                                                    @matricula.Curso?.HorarioFin.ToString("HH:mm")
                                                </p>
                                            </div>
                                        </div>
                                        
                                        <div class="row mt-2">
                                            <div class="col-12">
                                                <small class="text-muted">Fecha de inscripción:</small>
                                                <p class="mb-1">@matricula.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</p>
                                            </div>
                                        </div>

                                        @if (matricula.Estado == parcial.Models.EstadoMatricula.Pendiente)
                                        {
                                            <div class="mt-3">
                                                <div class="d-grid gap-2 d-md-flex">
                                                    <a asp-controller="Cursos" asp-action="Detalle" asp-route-id="@matricula.CursoId" 
                                                       class="btn btn-outline-primary btn-sm flex-fill">
                                                        <i class="fas fa-eye"></i> Ver Curso
                                                    </a>
                                                    <form asp-action="Cancelar" method="post" class="d-inline flex-fill">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@matricula.Id" />
                                                        <button type="submit" 
                                                                class="btn btn-outline-danger btn-sm w-100"
                                                                onclick="return confirm('¿Estás seguro de que deseas cancelar esta matrícula?')">
                                                            <i class="fas fa-times"></i> Cancelar
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="mt-3 d-grid">
                                                <a asp-controller="Cursos" asp-action="Detalle" asp-route-id="@matricula.CursoId" 
                                                   class="btn btn-outline-primary btn-sm">
                                                    <i class="fas fa-eye"></i> Ver Curso
                                                </a>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-graduation-cap fa-3x text-muted mb-3"></i>
                        <h5 class="text-muted">No tienes matrículas registradas</h5>
                        <p class="text-muted">
                            Explora nuestro catálogo de cursos y comienza tu proceso de inscripción.
                        </p>
                        <a asp-controller="Cursos" asp-action="Catalogo" class="btn btn-primary">
                            <i class="fas fa-search"></i> Ver Catálogo de Cursos
                        </a>
                    </div>
                }
            }
            else
            {
                <!-- Usuario no autenticado -->
                <div class="text-center py-5">
                    <i class="fas fa-user-lock fa-3x text-muted mb-3"></i>
                    <h5 class="text-muted">Inicia sesión para ver tus matrículas</h5>
                    <p class="text-muted">
                        Revisa el estado de tus inscripciones, consulta horarios y gestiona tus cursos matriculados.
                    </p>
                    <div class="mt-4">
                        <a asp-controller="Cursos" asp-action="Catalogo" class="btn btn-outline-secondary">
                            <i class="fas fa-search"></i> Explorar Catálogo de Cursos
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>