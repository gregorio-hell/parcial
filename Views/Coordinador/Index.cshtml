@model IEnumerable<parcial.Models.Curso>

@{
    ViewData["Title"] = "Panel de Coordinador";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="fas fa-user-tie"></i>
            Panel de Coordinador
        </h2>
        <a class="btn btn-success" asp-action="Create">
            <i class="fas fa-plus"></i>
            Crear Nuevo Curso
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="fas fa-book"></i>
                Gestión de Cursos
            </h5>
        </div>
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Código</th>
                                <th>Nombre</th>
                                <th>Créditos</th>
                                <th>Cupo Máximo</th>
                                <th>Horario</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var curso in Model)
                            {
                                <tr class="@(curso.Activo ? "" : "table-secondary")">
                                    <td>
                                        <strong>@curso.Codigo</strong>
                                    </td>
                                    <td>@curso.Nombre</td>
                                    <td>
                                        <span class="badge bg-info">@curso.Creditos</span>
                                    </td>
                                    <td>@curso.CupoMaximo</td>
                                    <td>
                                        <small class="text-muted">
                                            @curso.HorarioInicio.ToString("HH:mm") - @curso.HorarioFin.ToString("HH:mm")
                                        </small>
                                    </td>
                                    <td>
                                        @if (curso.Activo)
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check"></i> Activo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                <i class="fas fa-times"></i> Inactivo
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@curso.Id" title="Editar">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a class="btn btn-sm btn-outline-info" asp-action="Matriculas" asp-route-id="@curso.Id" title="Ver Matrículas">
                                                <i class="fas fa-users"></i>
                                            </a>
                                            @if (curso.Activo)
                                            {
                                                <form asp-action="Desactivar" method="post" style="display: inline;">
                                                    <input type="hidden" name="id" value="@curso.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-warning" 
                                                            onclick="return confirm('¿Está seguro de desactivar este curso?')" title="Desactivar">
                                                        <i class="fas fa-ban"></i>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-action="Activar" method="post" style="display: inline;">
                                                    <input type="hidden" name="id" value="@curso.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-success" 
                                                            onclick="return confirm('¿Está seguro de activar este curso?')" title="Activar">
                                                        <i class="fas fa-check"></i>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="fas fa-book fa-3x text-muted mb-3"></i>
                    <h5 class="text-muted">No hay cursos registrados</h5>
                    <p class="text-muted">Comience creando el primer curso del sistema.</p>
                    <a class="btn btn-primary" asp-action="Create">
                        <i class="fas fa-plus"></i>
                        Crear Primer Curso
                    </a>
                </div>
            }
        </div>
    </div>
</div>