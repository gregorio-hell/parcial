<!DOCTYPE html>
<html>
<head>
    <title>Portal Universitario</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-5">
        <div class="text-center">
            <h1 class="display-4">🎓 Portal Universitario</h1>
            <p class="lead">@ViewBag.Message</p>
            
            <div class="row mt-5">
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body">
                            <h5>📚 Catálogo</h5>
                            <p>Cursos disponibles</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body">
                            <h5>👨‍🎓 Estudiantes</h5>
                            <p>Matrículas</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body">
                            <h5>⚙️ Coordinador</h5>
                            <p>Panel administrativo</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="alert alert-success mt-4">
                ✅ Sistema funcionando correctamente
            </div>
        </div>
    </div>
</body>
</html>
